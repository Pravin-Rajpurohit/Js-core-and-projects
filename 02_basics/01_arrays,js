// chunk array into pages
function chunk(arr, size) {
  const result = [];
  for (let i = 0; i < arr.length; i += size) {
    result.push(arr.slice(i, i + size));
  }
  return result;
}
console.log(chunk([1,2,3,4,5,6,7], 3));
// [[1,2,3],[4,5,6],[7]]

// get unique values from array of objects
const tags = [{tag:"js"},{tag:"node"},{tag:"js"},{tag:"react"}];
const uniqueTags = [...new Set(tags.map(t => t.tag))];
console.log(uniqueTags); // ["js","node","react"]

// sum / min / max with reduce
const prices = [10, 5, 8, 20, 3];
const total  = prices.reduce((a, b) => a + b, 0);
const lowest = Math.min(...prices);
const highest = Math.max(...prices);
console.log(total, lowest, highest); // 46, 3, 20


// ── KEY GOTCHAS ──────────────────────────────────

// ⚠️ sort mutates original — copy first if needed
const original = [3, 1, 2];
const sorted = [...original].sort((a, b) => a - b);
console.log(original); // [3,1,2] — untouched

// ⚠️ indexOf uses === so fails for objects
const objs = [{id:1}, {id:2}];
console.log(objs.indexOf({id:1})); // -1 ❌ use find() instead

// ⚠️ map/filter/reduce don't mutate — always return new array
const orig = [1, 2, 3];
orig.map(n => n * 2); // return value ignored!
console.log(orig);    // [1,2,3] unchanged

// ⚠️ default sort is string-based
console.log([10, 9, 2, 1, 100].sort()); // [1,10,100,2,9] ❌
console.log([10, 9, 2, 1, 100].sort((a, b) => a - b)); // ✅