// ── 1. Creating Arrays ───────────────────────────
const a1 = [1, 2, 3];
const a2 = new Array(3).fill(0);       // [0, 0, 0]
const a3 = Array.from("hello");        // ["h","e","l","l","o"]
const a4 = Array.from({length: 5}, (_, i) => i + 1); // [1,2,3,4,5]
const a5 = [...a1, ...a2];             // spread to merge


// ── 2. Add / Remove ──────────────────────────────
const arr = [1, 2, 3];

arr.push(4);          // add to end    → [1,2,3,4]
arr.pop();            // remove end    → [1,2,3]
arr.unshift(0);       // add to start  → [0,1,2,3]
arr.shift();          // remove start  → [1,2,3]

// splice(start, deleteCount, ...items)
arr.splice(1, 1);          // remove index 1  → [1,3]
arr.splice(1, 0, 2);       // insert at index 1 → [1,2,3]
arr.splice(1, 1, 99);      // replace index 1 → [1,99,3]


// ── 3. Searching ─────────────────────────────────
const nums = [1, 2, 3, 4, 5, 3];

console.log(nums.indexOf(3));          // 2 (first index)
console.log(nums.lastIndexOf(3));      // 5 (last index)
console.log(nums.includes(4));         // true
console.log(nums.find(n => n > 3));    // 4 (first match)
console.log(nums.findIndex(n => n > 3)); // 3 (index of first match)
console.log(nums.findLast(n => n < 4));  // 3 (ES2023)


// ── 4. Iteration ─────────────────────────────────
const fruits = ["apple", "banana", "mango"];

// forEach — just loop, returns nothing
fruits.forEach((item, index) => {
  console.log(index, item);
});

// for...of — cleanest loop, use when you need break/continue
for (const fruit of fruits) {
  console.log(fruit);
}

// entries() — loop with index
for (const [i, fruit] of fruits.entries()) {
  console.log(i, fruit);
}


// ── 5. Transform ─────────────────────────────────
const numbers = [1, 2, 3, 4, 5];

// map — transform each item, returns new array
const doubled = numbers.map(n => n * 2);
console.log(doubled); // [2,4,6,8,10]

// filter — keep items that pass test
const evens = numbers.filter(n => n % 2 === 0);
console.log(evens); // [2,4]

// reduce — boil array down to single value
const sum = numbers.reduce((acc, n) => acc + n, 0);
console.log(sum); // 15

const max = numbers.reduce((acc, n) => n > acc ? n : acc, -Infinity);
console.log(max); // 5

// flatMap — map then flatten one level
const words = ["hello world", "foo bar"];
const chars = words.flatMap(w => w.split(" "));
console.log(chars); // ["hello","world","foo","bar"]


// ── 6. Sorting ───────────────────────────────────
const n = [10, 1, 5, 3, 8];

// ⚠️ default sort is alphabetical — always pass comparator
n.sort((a, b) => a - b); // ascending
console.log(n); // [1,3,5,8,10]

n.sort((a, b) => b - a); // descending
console.log(n); // [10,8,5,3,1]

// sort strings
const names = ["Pravin", "Alice", "Zara", "Bob"];
names.sort((a, b) => a.localeCompare(b));
console.log(names); // ["Alice","Bob","Pravin","Zara"]

// sort array of objects
const users = [
  { name: "Pravin", age: 21 },
  { name: "Alice",  age: 25 },
  { name: "Bob",    age: 19 }
];
users.sort((a, b) => a.age - b.age);
console.log(users); // sorted by age ascending


// ── 7. Slice vs Splice ───────────────────────────
const arr2 = [1, 2, 3, 4, 5];

// slice — non-mutating, returns portion
console.log(arr2.slice(1, 3));  // [2,3] (original unchanged)
console.log(arr2.slice(-2));    // [4,5]

// splice — mutates original
const removed = arr2.splice(1, 2); // removes 2 items from index 1
console.log(removed); // [2,3]
console.log(arr2);    // [1,4,5]


// ── 8. Flatten ───────────────────────────────────
const nested = [1, [2, 3], [4, [5, 6]]];

console.log(nested.flat());    // [1,2,3,4,[5,6]] — 1 level
console.log(nested.flat(2));   // [1,2,3,4,5,6]   — 2 levels
console.log(nested.flat(Infinity)); // fully flatten any depth


